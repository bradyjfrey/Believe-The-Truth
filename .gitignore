# Argon
/sourcemap.json

# Wally
/Packages
/ServerPackages
/DevPackages

# Artifacts
/*.lock
/*.rbxm
/*.rbxmx

# Place-file backups are big binaries — never commit them, in any folder.
# (Small .rbxm model exports under assets/ ARE intentionally tracked, so they
#  stay allowed — only the full-place .rbxl/.rbxlx are blocked everywhere.)
*.rbxl
*.rbxlx

# Audio source files — big binaries; upload to Roblox for asset IDs instead of
# committing. Keep them in assets/music/ locally; the repo tracks the IDs only.
*.mp3
*.ogg
*.wav
*.flac
*.m4a

# Local backups folder — kept in the repo dir for convenience, never tracked/pushed.
/• backups/

# Misc
.DS_Store
